{
  "manifest_version": 3,
  "name": "KhaosBox",
  "short_name": "KhaosBox",
  "description": "A new tab workspace for organizing links and notes.",
  "version": "0.1.0",
  "icons": {
    "16": "extension/icons/icon-16.png",
    "32": "extension/icons/icon-32.png",
    "48": "extension/icons/icon-48.png",
    "128": "extension/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "extension/pages/newtab.html"
  }
}
