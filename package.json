{
  "name": "khaosbox",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:extension": "vite build",
    "native-host:build": "dotnet build native-host/windows/KhaosBoxExplorer.csproj",
    "native-host:publish": "dotnet publish native-host/windows/KhaosBoxExplorer.csproj -c Release -r win-x64 --self-contained false -p:PublishSingleFile=true -o native-host/windows/build/win-x64",
    "native-host:msi": "powershell -ExecutionPolicy Bypass -File native-host/windows/build-msi.ps1",
    "native-host:install": "powershell -ExecutionPolicy Bypass -File native-host/windows/install.ps1",
    "native-host:uninstall": "powershell -ExecutionPolicy Bypass -File native-host/windows/uninstall.ps1",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/domains/workspace/model/workspaceModel.test.ts src/domains/items/services/createItem.test.ts src/features/item-management/services/createExternalDraftFromTransfer.test.ts src/platform/kbe/createKbeUrl.test.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
