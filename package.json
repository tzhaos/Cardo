{
  "name": "khaosbox",
  "productName": "KhaosBox",
  "private": true,
  "version": "0.0.0",
  "description": "A spatial workspace for your browser",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --config vite/extension.config.ts",
    "build": "vite build --config vite/extension.config.ts",
    "desktop:build": "vite build --config vite/desktop-renderer.config.ts && vite build --config vite/desktop-main.config.ts && vite build --config vite/desktop-preload.config.ts",
    "desktop:write-package": "tsx scripts/write-desktop-app-package.ts",
    "desktop:package": "npm run desktop:build && npm run desktop:write-package && electron-builder --win",
    "desktop:package:debug": "set \"KHAOSBOX_DEBUG_PACKAGE=1\"&& set \"KHAOSBOX_DESKTOP_PRODUCT_NAME=KhaosBox Debug\"&& npm run desktop:build && npm run desktop:write-package && electron-builder --win",
    "native-host:build": "vite build --config vite/native-host.config.ts && tsx scripts/package-native-host.ts",
    "native-host:install": "npm run native-host:build && tsx scripts/install-native-host.ts",
    "native-host:uninstall": "tsx scripts/uninstall-native-host.ts",
    "desktop:start": "npm run desktop:build && electron artifacts/desktop/main/main.js",
    "cli": "tsx src/cli/main.ts",
    "clean": "node -e \"const fs=require('node:fs'); ['artifacts','dist'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit && tsx scripts/check-architecture.ts",
    "lint:eslint": "node scripts/run-eslint.mjs .",
    "lint:fix": "node scripts/run-eslint.mjs . --fix",
    "check": "npm run lint && npm run lint:eslint && npm run test:ts",
    "format": "node scripts/run-prettier.mjs --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" \"README.md\" \"README_zh.md\" \"vite/*.ts\" \"eslint.config.js\"",
    "format:check": "node scripts/run-prettier.mjs --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" \"README.md\" \"README_zh.md\" \"vite/*.ts\" \"eslint.config.js\"",
    "test:ts": "tsx --test \"src/**/*.test.ts\"",
    "test": "npm run test:ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.0"
  },
  "build": {
    "electronVersion": "42.3.0",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "app": "artifacts/desktop",
      "output": "artifacts/desktop-dist"
    },
    "files": [
      "main/**",
      "renderer/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
