{
  "name": "cardo",
  "productName": "Cardo",
  "private": true,
  "version": "0.1.0",
  "description": "Cardo — local Runtime spatial workspace (CLI, Web, Extension, Desktop)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cardo": "./artifacts/cli/cardo.js"
  },
  "scripts": {
    "dev": "vite build --watch --config vite/extension.config.ts",
    "cardo:stop": "tsx scripts/stop-cardo-instances.ts",
    "build": "npm run cardo:stop && vite build --config vite/extension.config.ts",
    "build:all": "tsx scripts/build-all.ts",
    "release:build": "tsx scripts/build-pipeline.ts",
    "desktop:build": "npm run cardo:stop && vite build --config vite/web-runtime.config.ts && vite build --config vite/desktop-main.config.ts && vite build --config vite/desktop-preload.config.ts",
    "desktop:write-package": "tsx scripts/write-desktop-app-package.ts",
    "desktop:package": "npm run desktop:build && npm run desktop:write-package && electron-builder --win",
    "desktop:package:debug": "set \"CARDO_DEBUG_PACKAGE=1\"&& set \"CARDO_DESKTOP_PRODUCT_NAME=Cardo Debug\"&& npm run desktop:build && npm run desktop:write-package && electron-builder --win",
    "web-runtime:build": "vite build --config vite/web-runtime.config.ts",
    "cardo:build": "npm run cardo:stop && vite build --config vite/cli.config.ts && npm run web-runtime:build",
    "cardo": "node artifacts/cli/cardo.js",
    "native-host:build": "vite build --config vite/native-host.config.ts && tsx scripts/package-native-host.ts",
    "native-host:install": "npm run native-host:build && tsx scripts/install-native-host.ts",
    "native-host:uninstall": "tsx scripts/uninstall-native-host.ts",
    "desktop:start": "npm run desktop:build && electron artifacts/desktop/main/main.js",
    "clean": "node -e \"const fs=require('node:fs'); ['artifacts','dist'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit",
    "lint:eslint": "node scripts/run-eslint.mjs .",
    "lint:fix": "node scripts/run-eslint.mjs . --fix",
    "check": "npm run lint && npm run lint:eslint && npm run test:ts",
    "format": "node scripts/run-prettier.mjs --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" \"README.md\" \"README_zh.md\" \"vite/*.ts\" \"eslint.config.js\"",
    "format:check": "node scripts/run-prettier.mjs --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" \"README.md\" \"README_zh.md\" \"vite/*.ts\" \"eslint.config.js\"",
    "test:ts": "tsx --test \"src/**/*.test.ts\"",
    "test": "npm run test:ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fluentui/react-icons": "^2.0.333",
    "@fontsource-variable/inter": "^5.2.8",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.0"
  },
  "build": {
    "electronVersion": "42.3.0",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "app": "artifacts/desktop",
      "output": "artifacts/desktop-dist"
    },
    "files": [
      "main/**"
    ],
    "icon": "assets/brand/cardo-icon.ico",
    "win": {
      "icon": "assets/brand/cardo-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/brand/cardo-icon-512.png",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "assets/brand/cardo-icon-512.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
