{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c).on(\"end\",()=>{let cmd=\"\";try{cmd=(JSON.parse(d).tool_input||{}).command||\"\"}catch{}if(!/\\bgit\\b[^\\n;&|]*\\bcommit\\b/.test(cmd))process.exit(0);const{execFileSync}=require(\"node:child_process\");const root=process.env.CLAUDE_PROJECT_DIR||\".\";try{execFileSync(process.execPath,[root+\"/.spec/tools/spec-lint.mjs\",root],{stdio:\"pipe\"});process.exit(0)}catch(e){process.stderr.write(\"spec-lint failed; fix before git commit\\n\"+String(e.stdout||\"\")+String(e.stderr||\"\"));process.exit(2)}})'"
          }
        ]
      }
    ]
  }
}
